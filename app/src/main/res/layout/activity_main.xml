<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <androidx.camera.view.PreviewView
                    android:id="@+id/previewView"
                    android:layout_width="match_parent"
                    android:layout_height="420dp"
                    android:contentDescription="Camera preview" />

                <TextView
                    android:id="@+id/tvZoomLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Zoom kamera: 1.0x"
                    android:textStyle="bold" />

                <SeekBar
                    android:id="@+id/seekZoom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="0" />

                <Button
                    android:id="@+id/btnCapture"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Ambil Foto Portrait" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <com.imam.app2.MeasurementImageView
                    android:id="@+id/measurementView"
                    android:layout_width="match_parent"
                    android:layout_height="420dp"
                    android:adjustViewBounds="true"
                    android:background="#EEEEEE"
                    android:contentDescription="Measurement preview"
                    android:scaleType="fitCenter" />

                <Spinner
                    android:id="@+id/spinnerCommonObject"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp" />

                <Button
                    android:id="@+id/btnEstimateCommon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Perkirakan Ukuran Umum Objek Aktif" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etKnownSizeCm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ukuran referensi nyata (cm)"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSetKnown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tetapkan Garis Aktif Sebagai Referensi" />

                <Button
                    android:id="@+id/btnEstimateUnknown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Estimasi Ukuran Garis Aktif" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etActualSizeForDistanceCm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ukuran nyata garis aktif untuk hitung jarak (cm)"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnEstimateDistance"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hitung Jarak Kamera ke Objek" />

                <Button
                    android:id="@+id/btnReset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reset Garis" />

                <TextView
                    android:id="@+id/tvInstructions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Cara pakai:\n1. Kamera selalu portrait.\n2. Gunakan slider zoom sebelum ambil foto.\n3. Ambil foto, lalu ketuk 2 titik pada objek aktif.\n4. Untuk benda umum, pilih kategori lalu tekan tombol perkiraan ukuran umum.\n5. Untuk hasil lebih presisi, pakai objek referensi nyata.\n6. Setelah ukuran aktif terisi, tekan hitung jarak." />

                <TextView
                    android:id="@+id/tvResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Hasil akan muncul di sini"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
