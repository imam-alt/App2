<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.imam.app2.MeasurementImageView
            android:id="@+id/measurementView"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:adjustViewBounds="true"
            android:background="#EEEEEE"
            android:contentDescription="Measurement preview"
            android:scaleType="fitCenter" />

        <Button
            android:id="@+id/btnCapture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ambil Foto" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etKnownSizeCm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ukuran referensi nyata (cm)"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnSetKnown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tetapkan Garis Aktif Sebagai Referensi" />

        <Button
            android:id="@+id/btnEstimateUnknown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estimasi Ukuran Garis Aktif" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etActualSizeForDistanceCm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ukuran nyata garis aktif untuk hitung jarak (cm)"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btnEstimateDistance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hitung Jarak Kamera ke Objek" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reset Garis" />

        <TextView
            android:id="@+id/tvInstructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Cara pakai:\n1. Ambil foto.\n2. Ketuk 2 titik pada objek referensi.\n3. Isi ukuran aslinya, lalu tekan tombol referensi.\n4. Ketuk 2 titik pada objek lain untuk estimasi ukuran.\n5. Untuk jarak, isi ukuran nyata garis aktif atau gunakan hasil estimasi ukuran."
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Hasil akan muncul di sini"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
